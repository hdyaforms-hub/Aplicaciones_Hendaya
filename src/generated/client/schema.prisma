generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model User {
  id           String           @id @default(uuid())
  username     String           @unique
  email        String?          @unique
  passwordHash String
  name         String?
  roleId       String
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  role         Role             @relation(fields: [roleId], references: [id])
  sucursales   Sucursal[]       @relation("SucursalToUser")
  allowedForms FormDefinition[] @relation("UserForms")
  areas        Area[]           @relation("UserAreas")
}

model PMPA {
  id         String   @id @default(uuid())
  sucursal   String
  ano        Int
  mes        Int
  rbd        Int
  licId      Int?
  programa   String
  estrato    String
  raceq      Int
  servicio   String
  uploadedBy String
  createdAt  DateTime @default(now())
}

model Colegios {
  id                       String @id @default(uuid())
  colut                    Int
  colRBD                   Int
  colRBDDV                 String
  insid                    String
  institucion              String
  sucursal                 String
  nombreEstablecimiento    String
  direccionEstablecimiento String
  comuna                   String
  uploadedBy               String
}

model IngRacion {
  id                    String   @id @default(uuid())
  usuario               String
  ubicacion             String
  fechaSistema          DateTime @default(now())
  fechaIngreso          DateTime
  rbd                   Int
  licId                 Int?
  nombreEstablecimiento String
  ano                   Int
  mes                   Int
  programa              String
  estrato               String
  desayunoIng           Int
  almuerzoIng           Int
  onceIng               Int
  colacionIng           Int
  cenaIng               Int
  totalIng              Int
  desayunoAsig          Int
  almuerzoAsig          Int
  onceAsig              Int
  colacionAsig          Int
  cenaAsig              Int
  totalAsig             Int
  tasaPreparacion       Float
  observacion           String
}

model Productos {
  id           String @id @default(uuid())
  nombre       String
  codigo       String
  unidad       String
  tipoProducto Int
}

model EmailConfig {
  id        String   @id @default("global")
  email     String
  password  String
  provider  String   @default("office365")
  updatedBy String?
  updatedAt DateTime @updatedAt
}

model ListaCorreo {
  id             String                 @id @default(uuid())
  nombre         String                 @unique
  descripcion    String?
  para           String
  cc             String?
  sucursalId     String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  sucursal       Sucursal?              @relation(fields: [sucursalId], references: [id])
  notificaciones NotificacionPantalla[]
}

model NotificacionPantalla {
  id             String      @id @default(uuid())
  codigoPantalla String
  listaCorreoId  String
  activa         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  listaCorreo    ListaCorreo @relation(fields: [listaCorreoId], references: [id])

  @@unique([codigoPantalla, listaCorreoId])
}

model PlantillaCorreo {
  id             String   @id @default(uuid())
  codigoPantalla String   @unique
  asunto         String
  cuerpo         String
  updatedAt      DateTime @updatedAt
}

model Licitacion {
  licId     Int      @id @default(autoincrement())
  estado    Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  uts       UT[]
}

model Sucursal {
  id                             String                           @id @default(uuid())
  nombre                         String                           @unique
  createdAt                      DateTime                         @default(now())
  updatedAt                      DateTime                         @updatedAt
  listasCorreo                   ListaCorreo[]
  presupuestos                   Presupuesto[]
  RetornoProductosMovimiento     RetornoProductosMovimiento[]
  RetornoProductosSucursalEstado RetornoProductosSucursalEstado[]
  uts                            UT[]
  users                          User[]                           @relation("SucursalToUser")
}

model Presupuesto {
  id         String   @id @default(uuid())
  ano        Int
  sucursalId String
  montoAnual Float
  usuario    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id])

  @@unique([ano, sucursalId])
}

model SolicitudPan {
  id                String   @id @default(uuid())
  ut                Int
  licId             Int?
  rbd               Int
  nombreSolicitante String
  fechaSolicitud    DateTime @default(now())
  solicitud         String
  cantidad          Int
  fechaGestacion    DateTime
  servicio          String
  motivo            String
}

model UT {
  codUT      Int        @id @default(autoincrement())
  licId      Int
  estado     Int        @default(1)
  sucursalId String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  licitacion Licitacion @relation(fields: [licId], references: [licId])
  sucursal   Sucursal?  @relation(fields: [sucursalId], references: [id])
}

model SolicitudGas {
  id                String   @id @default(uuid())
  ut                Int
  licId             Int?
  rbd               Int
  nombreSolicitante String
  fechaSolicitud    DateTime @default(now())
  distribuidor      String
  tipoGas           String
  cantidadLitro     Float
  cilindro          String?
  cantidad          Int?
  observacion       String?
  createdAt         DateTime @default(now())
}

model RetiroSaldoHeader {
  id                    String              @id @default(uuid())
  folio                 String              @unique
  tipoOperacion         String
  rbd                   Int
  nombreEstablecimiento String
  ut                    Int
  licId                 Int?
  sucursal              String
  fecha                 DateTime            @default(now())
  supervisor            String
  nombreAutoriza        String?
  rutAutoriza           String?
  firmaBase64           String?
  createdAt             DateTime            @default(now())
  detalles              RetiroSaldoDetail[]
}

model RetiroSaldoDetail {
  id             String            @id @default(uuid())
  headerId       String
  codigoProducto String
  nombreProducto String
  cantidad       Int
  createdAt      DateTime          @default(now())
  header         RetiroSaldoHeader @relation(fields: [headerId], references: [id])
}

model Mat_ConsumoGas {
  id        String   @id @default(uuid())
  rbd       Int      @unique
  litros    Float
  cantidad  Int
  meses     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FormDefinition {
  id           String           @id @default(uuid())
  title        String
  description  String?
  fields       String
  createdBy    String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  isActive     Boolean          @default(true)
  formCode     String?
  formVersion  String?
  formDate     String?
  areaId       Int?
  area         Area?            @relation(fields: [areaId], references: [id])
  schedules    FormSchedule[]
  submissions  FormSubmission[]
  allowedUsers User[]           @relation("UserForms")
}

model Area {
  id        Int              @id @default(autoincrement())
  nombre    String           @unique
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  forms     FormDefinition[]
  users     User[]           @relation("UserAreas")
}

model FormSchedule {
  id        String         @id @default(uuid())
  formId    String
  startDay  Int
  startTime String
  endDay    Int
  endTime   String
  createdAt DateTime       @default(now())
  form      FormDefinition @relation(fields: [formId], references: [id], onDelete: Cascade)
}

model FormSubmission {
  id          String         @id @default(uuid())
  formId      String
  data        String
  submittedBy String
  submittedAt DateTime       @default(now())
  form        FormDefinition @relation(fields: [formId], references: [id])
}

model Mat_ConsumoGasHistory {
  id           String   @id @default(uuid())
  rbd          Int
  litros       Float
  cantidad     Int
  meses        String
  old_litros   Float?
  old_cantidad Int?
  old_meses    String?
  observacion  String
  user         String
  createdAt    DateTime @default(now())
}

model Anexo {
  id        String   @id @default(uuid())
  sucursal  String
  cargo     String
  correo    String
  telefono1 String
  telefono2 String?
  telefono3 String?
  telefono4 String?
  nombre    String
  cumpleano String?
  contacto  String?
  nota      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

