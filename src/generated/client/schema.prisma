model ColegiosMatriz {
  id                    String   @id @default(uuid())
  colRBD                Int      @unique
  nombreEstablecimiento String
  institucion           String
  sucursal              String
  colut                 Int
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model MatrizConfigPregunta {
  id           String   @id @default(uuid())
  preguntaId   String   @unique
  seccion      String
  gravedad     Int
  probabilidad Int
  nivelRiesgo  String
  updatedAt    DateTime @updatedAt
}

model MatrizConfigSemestre {
  id        String   @id @default(uuid())
  anio      Int      @unique @default(2026)
  fechaFin1 DateTime
  updatedAt DateTime @updatedAt
}

model MatrizMitigacion {
  id            String    @id @default(uuid())
  matrizId      String
  preguntaId    String
  fechaSolucion DateTime?
  adjuntos      String?
  usuario       String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([matrizId, preguntaId])
}

model TrabajoPreventivo {
  id                    String   @id @default(uuid())
  ut                    Int
  sucursal              String
  licitacion            String
  rbd                   Int
  nombreEstablecimiento String
  folioOT               String
  tipoTrabajo           String
  fechaTrabajo          DateTime
  documentoAsociado     String
  boletasFacturas       String?
  montoMateriales       Int?
  montoManoObra         Int?
  observacion           String?
  usuario               String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model RetornoProductosAlerta {
  id               String                           @id @default(uuid())
  titulo           String
  observacion      String                           @db.NVarChar(1500)
  horas            Int
  estado           String                           @default("ABIERTA")
  color            String?                          @default("yellow")
  archivos         String?
  usuarioCreacion  String
  fechaCreacion    DateTime                         @default(now())
  usuarioCierre    String?
  fechaCierre      DateTime?
  conclusionFinal  String?                          @db.NVarChar(Max)
  movimientos      RetornoProductosMovimiento[]
  sucursalesEstado RetornoProductosSucursalEstado[]
}

model RetornoProductosSucursalEstado {
  id            String                 @id @default(uuid())
  alertaId      String
  sucursalId    String
  estado        String                 @default("PENDIENTE")
  usuarioCierre String?
  fechaCierre   DateTime?
  alerta        RetornoProductosAlerta @relation(fields: [alertaId], references: [id], onDelete: Cascade)
  sucursal      Sucursal               @relation(fields: [sucursalId], references: [id])

  @@unique([alertaId, sucursalId])
}

model RetornoProductosMovimiento {
  id              String                 @id @default(uuid())
  alertaId        String
  sucursalId      String
  usuarioRegistro String
  comentario      String                 @db.NVarChar(Max)
  archivos        String?
  fechaRegistro   DateTime               @default(now())
  alerta          RetornoProductosAlerta @relation(fields: [alertaId], references: [id], onDelete: Cascade)
  sucursal        Sucursal               @relation(fields: [sucursalId], references: [id])
}

model RetornoProductosAlertaHistorialEliminado {
  id                String   @id @default(uuid())
  alertaIdOriginal  String
  tituloAlerta      String
  observacionAlerta String   @db.NVarChar(Max)
  motivoEliminacion String   @db.NVarChar(Max)
  usuarioEliminador String
  fechaEliminacion  DateTime @default(now())
}
